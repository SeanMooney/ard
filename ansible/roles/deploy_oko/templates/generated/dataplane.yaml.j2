# Rendered by ARD deploy_oko from the ARD inventory. This file is intended
# as input for the real OKO dataplane deployment once CRDs/operators exist.
{% set ssh_key = lookup('file', oko_edpm_ssh_private_key_path, errors='ignore') | default('', true) %}
{% if ssh_key | length > 0 %}
apiVersion: v1
kind: Secret
metadata:
  name: {{ oko_edpm_ssh_secret_name }}
  namespace: {{ oko_namespace }}
type: Opaque
stringData:
  ssh-privatekey: |
{% for line in ssh_key.splitlines() %}
    {{ line }}
{% endfor %}
---
{% endif %}
apiVersion: dataplane.openstack.org/v1beta1
kind: OpenStackDataPlaneDeployment
metadata:
  name: {{ oko_edpm_deployment_name }}
  namespace: {{ oko_namespace }}
spec:
  nodeSets:
    - {{ oko_edpm_nodeset_name }}
---
apiVersion: dataplane.openstack.org/v1beta1
kind: OpenStackDataPlaneNodeSet
metadata:
  name: {{ oko_edpm_nodeset_name }}
  namespace: {{ oko_namespace }}
spec:
  env:
    - name: ANSIBLE_FORCE_COLOR
      value: "True"
  networkAttachments:
    - ctlplane
  preProvisioned: true
  tlsEnabled: false
  nodeTemplate:
    ansible:
      ansibleUser: {{ oko_edpm_ansible_user }}
      ansibleVars:
        gather_facts: false
        image_tag: {{ oko_image_tag }}
        registry_url: {{ oko_registry_url }}
        edpm_nodes_validation_validate_controllers_icmp: false
        edpm_nodes_validation_validate_gateway_icmp: false
{% if oko_edpm_bridge_veth_enabled | bool %}
        edpm_network_config_nonconfigured_cleanup: false
{% endif %}
        neutron_public_interface_name: {{ oko_edpm_public_interface_name }}
    ansibleSSHPrivateKeySecret: {{ oko_edpm_ssh_secret_name }}
  nodes:
{% for node in oko_edpm_nodes %}
    {{ node.name }}:
      hostName: {{ node.hostname }}
      ansible:
        ansibleHost: {{ node.ansible_host }}
      networks:
        - name: ctlplane
          subnetName: subnet1
          defaultRoute: true
          fixedIP: {{ node.ansible_host }}
{% endfor %}
  services:
    - repo-setup
    - bootstrap
    - download-cache
    - configure-network
    - validate-network
    - install-os
    - configure-os
    - ssh-known-hosts
    - run-os
    - reboot-os
    - ovn
    - neutron-metadata
    - libvirt
    - nova
